---
interface Props {
  title: string;
  text: string;
  href: string;
  bubbleImage: string;
  bubbleAlt?: string;
  direction?: "left" | "right";
}

const {
  title,
  text,
  href,
  bubbleImage,
  bubbleAlt = "",
  direction = "right"
} = Astro.props;
---

<article class:list={["speech-cta", `speech-cta--${direction}`]}>
  <a href={href} class="speech-cta__bubble">
    <img src={bubbleImage} alt={bubbleAlt} />
    <span class="speech-cta__title">{title}</span>
  </a>

  <p class="speech-cta__text">{text}</p>
</article>

<style>
  .speech-cta {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: clamp(5rem, 24vw, 7rem) 1fr;
    align-items: center;
    gap: clamp(0.5rem, 2vw, 0.8rem);
  }

  .speech-cta--left {
    grid-template-columns: 1fr clamp(5rem, 24vw, 7rem);
  }

  .speech-cta--left .speech-cta__bubble {
    order: 2;
  }

  .speech-cta--left .speech-cta__text {
    order: 1;
  }

  .speech-cta__bubble {
    position: relative;
    display: block;
    width: 100%;
  }

  .speech-cta__bubble img {
    display: block;
    width: 100%;
    height: auto;
  }

  .speech-cta__title {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: clamp(0.5rem, 2vw, 0.9rem);
    text-align: center;
    text-transform: uppercase;
    font-size: clamp(0.6rem, 2.8vw, 0.9rem);
    line-height: 1;
    font-weight: 700;
    color: #a16d5f;
  }

  .speech-cta__text {
    padding-bottom: 0.35rem;
    border-bottom: 1px solid #010326;
    text-align: center;
    font-size: clamp(0.7rem, 2.4vw, 0.75rem);
    line-height: 1.4;
  }
@media (min-width: 768px) {
  .speech-cta {
    display: grid;
    grid-template-columns: auto auto;
    justify-content: start;
    align-items: center;
    column-gap: 2rem;
    row-gap: 0;
    margin-top: 0;
  }

  .speech-cta--left {
    justify-content: end;
    grid-template-columns: auto auto;
  }

  .speech-cta__bubble {
    width: 25rem;
  }

  .speech-cta__bubble img {
    display: block;
    width: 100%;
    height: auto;
  }

  .speech-cta__title {
    font-size: 2.5rem;
    padding: 3rem;
    text-decoration: underline;
  }

  .speech-cta__text {
    width: 40rem;
    font-size: 2rem;
    line-height: 1.5;
    text-align: center;
    border-bottom: 1px solid #343551;
    padding-bottom: 0.75rem;
  }

  .speech-cta:not(.speech-cta--left) .speech-cta__bubble {
    order: 1;
  }

  .speech-cta:not(.speech-cta--left) .speech-cta__text {
    order: 2;
  }

  .speech-cta--left .speech-cta__text {
    order: 1;
  }

  .speech-cta--left .speech-cta__bubble {
    order: 2;
  }
}
  </style>