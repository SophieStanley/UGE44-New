---
interface Props {
  text: string;
  href?: string;
  image: string;
  variant?: "button" | "link";
  class?: string;
}

const {
  text,
  href,
  image,
  variant = "link",
  class: className = "",
  ...rest
} = Astro.props;
---

{variant === "button" ? (
  <button class={`paper-cta ${className}`} {...rest}>
    <img class="paper-cta__bg" src={image} alt="" />
    <span class="paper-cta__text">{text}</span>
  </button>
) : (
  <a href={href} class={`paper-cta ${className}`} {...rest}>
    <img class="paper-cta__bg" src={image} alt="" />
    <span class="paper-cta__text">{text}</span>
  </a>
)}