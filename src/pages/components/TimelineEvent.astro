---
interface EventItem {
  id: number;
  title: string;
  description: string;
  location: string;
  event_date: string;
  event_time: string;
  image: string;
}

interface Props {
  event: EventItem;
}

const { event } = Astro.props;

const formattedDate = new Date(event.event_date).toLocaleDateString("da-DK", {
  day: "numeric",
  month: "long",
  year: "numeric"
});
---

<li class="timeline-item" data-location={event.location.toLowerCase()}>
  <div class="timeline-marker" aria-hidden="true"></div>

  <article class="event-card">
    {event.image && (
      <div class="event-card__image-wrap">
        <img src={event.image} alt={event.title} class="event-card__image" />
      </div>
    )}

    <div class="event-card__content">
      <p class="event-card__meta">
        <span>{formattedDate}</span>
        <span>·</span>
        <span>{event.event_time}</span>
        <span>·</span>
        <span>{event.location}</span>
      </p>

      <h2>
  <a href={`/kalender/${event.id}`}>{event.title}</a>
</h2>
      <p>{event.description}</p>

      <a class="event-card__link" href={`/kalender/${event.id}`}>Læs mere</a>

      <button
        class="event-card__cta"
        type="button"
        data-open-signup
        data-event-title={event.title}
      >
        Tilmeld
      </button>
    </div>
  </article>
</li>

<style>
  .timeline-item {
    position: relative;
    padding-left: 2rem;
  }

  .timeline-marker {
    position: absolute;
    top: 1.2rem;
    left: 0;
    width: 1rem;
    height: 1rem;
    border: 2px solid #010326;
    border-radius: 999px;
    background: #faf7f2;
    z-index: 1;
  }

  .event-card {
    display: grid;
    gap: 0.75rem;
    padding: 0.875rem;
    background: #f3eee7;
    border: 1px solid rgba(1, 3, 38, 0.15);
  }

  .event-card__image-wrap {
    overflow: hidden;
  }

  .event-card__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .event-card__content {
    display: grid;
    gap: 0.65rem;
  }

  .event-card__meta {
    font-size: 0.82rem;
    line-height: 1.3;
    color: #343551;
  }

  .event-card h2 {
    font-size: 1.25rem;
    line-height: 1.05;
    text-transform: uppercase;
    color: #010326;
    font-weight: 700;
  }

  .event-card p {
    font-size: 0.95rem;
    line-height: 1.45;
    color: #010326;
  }

  .event-card__cta {
    width: fit-content;
    border: 0;
    padding: 0.7rem 1rem;
    background: #D99282;
    color: #fefdfc;
    font-size: 0.8rem;
    text-transform: uppercase;
    text-decoration: underline;
    cursor: pointer;
  }
  @media (min-width: 768px){
    .event-card h2 {
    font-size: 2rem;
    }
    .event-card p {
    font-size: 1.5rem;
  }
    .event-card__cta {
    display: block;
    margin-inline: auto;
    font-size: 1.5rem;
  }
  .event-card__image{
    aspect-ratio: 16 / 9;
    
  }
}
</style>