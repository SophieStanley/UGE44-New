---
import BaseLayout from "./layouts/BaseLayout.astro";
import FeatureCard from "./components/FeatureCard.astro";
import BubbleCTA from "./components/BubbleCTA.astro";
import "./styles/index.css";
import "./styles/general.css";


type Card = {
  title: string;
  text: string;
  image: string;
  imageAlt: string;
  buttonText: string;
  href: string;
  buttonVariant: "dark" | "light";
};

const cards: Card[] = [
  {
    title: "Fælleslæsning om døden",
    text: "Et arrangement, hvor litteratur og samtale skaber rum for fælles refleksion over død, sorg og minde.",
    image: "/imgs/fælles.webp",
    imageAlt: "Bog og hænder",
    buttonText: "Se kalender",
    href: "/kalender",
    buttonVariant: "dark"
  },
  {
    title: "Tag plasteret af",
    text: "I forbindelse med vores kampagne Uge 44, har vi kreeret et safe space hvor du anonymt kan dele dine tanker.",
    image: "/imgs/image.webp",
    imageAlt: "Person ved bord",
    buttonText: "Del tanker",
    href: "/tag-plasteret-af",
    buttonVariant: "dark"
  },
  {
    title: "Logo og presse",
    text: "Herunder finder I logoer og andet materiale til kampagneugen UGE 44- Fokus på døden.",
    image: "/imgs/presse.webp",
    imageAlt: "Illustration med personer",
    buttonText: "Læs mere",
    href: "/presse-logo-kontakt",
    buttonVariant: "dark"
  }
];
---

<BaseLayout title="Forside | Uge 44">
  <section class="hero">
    <div class="hero-figure">
      <img src="/imgs/hero-grafik-merged.webp" alt="" />
    </div>

    <div class="hero-bubble">
      <img class="hero-bubble-bg" src="/imgs/talebobel-2.webp" alt="" />
      <div class="hero-content">
        <h1>Lad os tale om det der er svært</h1>
        <p>
          Gennem Uge 44 skaber vi et trygt og uformelt rum, hvor unge kan dele
          tanker om liv, død og sorg, uden forventninger
        </p>
        <a href="/om-os" class="hero-button">Læs mere</a>
      </div>
    </div>
  </section>

  <section class="feature-section">
    <div class="feature-list">
      {cards.map((card) => (
        <FeatureCard
          title={card.title}
          text={card.text}
          image={card.image}
          imageAlt={card.imageAlt}
          buttonText={card.buttonText}
          href={card.href}
          buttonVariant={card.buttonVariant}
        />
      ))}
    </div>
  </section>

  <section class="resource-section">
    <div class="resource-list">
      <BubbleCTA
        title="Filmliste"
        text="Klik på taleboblen for at se en oversigt over forskellige spillefilm, kortfilm og dokumentarer, der handler om døden."
        href="/filmliste"
        bubbleImage="/imgs/talebobel-højre.png"
        direction="right"
      />

      <BubbleCTA
        title="Bogliste"
        text="Klik på taleboblen for at se en oversigt over forskellige digtsamlinger, børnebøger, skønlitteratur og beretninger om døden."
        href="/bogliste"
        bubbleImage="/imgs/talebobel-venstre.png"
        direction="left"
      />
    </div>
  </section>
</BaseLayout>