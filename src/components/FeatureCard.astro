---
interface Props {
  title: string;
  text: string;
  image: string;
  imageAlt: string;
  buttonText: string;
  href: string;
  buttonVariant?: "dark" | "light";
}

const {
  title,
  text,
  image,
  imageAlt,
  buttonText,
  href,
  buttonVariant = "dark"
} = Astro.props;
---

<article class="feature-card">
  <img
    class="feature-card__paper"
    src="/imgs/card-hori.webp"
    alt=""
  />

  <div class="feature-card__inner">
    <div class="feature-card__image">
      <img src={image} alt={imageAlt} />
    </div>

    <div class="feature-card__content">
      <h2>{title}</h2>
      <p>{text}</p>
      <a
        href={href}
        class:list={[
          "feature-card__button",
          buttonVariant === "light" && "feature-card__button--light"
        ]}
      >
        {buttonText}
      </a>
    </div>
  </div>
</article>

<style>
    .feature-list {
  width: min(100%, 22rem);
  margin-inline: auto;
}
    .feature-card{
        position: relative;
        width: 100%;
    }
    .feature-card__paper{
        width: 100%;
        height: auto;
        display: block;
    }
    .feature-card__inner{
        position: absolute;
        inset: 0;
        display: grid;
         grid-template-columns: clamp(4rem, 20vw, 6rem) 1fr;
        align-items: center;
        gap: 0.9;
        padding: 1rem 1rem 1rem 1.1rem;
    }
     .feature-card__image {
     width: clamp(4rem, 20vw, 6rem);
  height: clamp(4rem, 20vw, 6rem);
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: right;
    margin-left: 1.5rem;
  }
    .feature-card__image img{
        width: 100%;
        max-width: 8rem;
        height: auto;
        object-fit: cover;
    }
      .feature-card__content {
    text-align: center;
  }
    .feature-card__content h2 {
        color: #010326;
    margin-bottom: 0.35rem;
     font-size: clamp(0.8rem, 3vw, 1rem);
    line-height: 1.05;
    text-transform: uppercase;
  }
   .feature-card__content p {
    color: #010326;
    margin: 0 auto 0.55rem;
    max-width: 21ch;
     font-size: clamp(0.55rem, 2.5vw, 0.7rem);
    line-height: 1.35;
  }
    .feature-card__button {
        background-color: #343551;
    display: inline-block;
    padding: 0.5rem 0.75rem;
    color: #fff;
    font-size: 0.8rem;
    line-height: 1;
    text-decoration: underline;
    text-transform: uppercase;
    border-radius: 999px;
  }
  @media (min-width: 768px) {
  
  .feature-card {
    max-width: 19rem;
    margin-inline: auto;
  }

  .feature-card__paper {
    aspect-ratio: 2.5 / 4.5;
    object-fit: cover;
  }

  .feature-card__inner {
    inset: 0;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto auto 1fr auto;
    justify-items: center;
    align-content: start;
    gap: 0.8rem;
    padding: 7rem 1.2rem 1.6rem;
  }

  .feature-card__image {
  width: 10rem;
  height: 8.5rem;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 0;
  }

  .feature-card__image img {
    width: 100%;
  height: 100%;
  max-width: none;
  object-fit: cover;
  object-position: center;
  }

  .feature-card__content {
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .feature-card__content h2 {
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.6rem;
    max-width: 14ch;
  }

  .feature-card__content p {
    font-size: 1.2rem;
    line-height: 1.45;
    max-width: 20ch;
    margin-bottom: 1rem;
  }

  .feature-card__button {
    font-size: 1.2rem;
    font-weight: 700;
    padding: 0.55rem 1rem;
  }
}
</style>