---
interface Props {
  text: string;
  href?: string;
  direction?: "left" | "right";
  className?: string;
}

const {
  href = "",
  text,
  direction = "right",
  className = "",
} = Astro.props;

const isInternal = typeof href === "string" && href.startsWith("/");
const isExternal = typeof href === "string" && !isInternal && href !== "";
---

<a
  href={href}
  class={`bubble-link bubble-link--${direction} ${className}`}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
>
  <span class="bubble-link__text">{text}</span>
</a>
