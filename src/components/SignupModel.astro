<div class="signup-modal" id="signup-modal" hidden>
  <div class="signup-modal__overlay" data-close-signup></div>

  <div
    class="signup-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="signup-title"
  >
    <button class="signup-modal__close" type="button" data-close-signup aria-label="Luk popup">
      ×
    </button>

    <p class="signup-modal__eyebrow">Tilmelding</p>
    <h2 id="signup-title">Tilmeld dig event</h2>
    <p class="signup-modal__event" id="signup-event-name"></p>

    <form class="signup-form">
      <label for="name">Navn</label>
      <input id="name" name="name" type="text" required />

      <label for="email">E-mail</label>
      <input id="email" name="email" type="email" required />

      <label for="message">Besked</label>
      <textarea id="message" name="message" rows="4"></textarea>

      <button type="submit">Send tilmelding</button>
    </form>
  </div>
</div>

<style>
  .signup-modal[hidden] {
    display: none;
  }

  .signup-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .signup-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(1, 3, 38, 0.55);
  }

  .signup-modal__dialog {
    position: relative;
    width: min(calc(100% - 1rem), 32rem);
    margin: 4rem auto 0;
    padding: 1rem;
    background: #faf7f2;
    border: 1px solid rgba(1, 3, 38, 0.15);
    z-index: 1;
  }

  .signup-modal__close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    border: 0;
    background: transparent;
    font-size: 1.5rem;
    cursor: pointer;
    color: #010326;
  }

  .signup-modal__eyebrow {
    margin-bottom: 0.4rem;
    color: #343551;
  }

  .signup-modal h2 {
    margin-bottom: 0.5rem;
    font-size: 1.6rem;
    text-transform: uppercase;
    font-weight: 700;
    color: #010326;
  }

  .signup-modal__event {
    margin-bottom: 1rem;
    color: #343551;
  }

  .signup-form {
    display: grid;
    gap: 0.75rem;
  }

  .signup-form label {
    font-family: "Glacial Indifference", sans-serif;
    color: #010326;
  }

  .signup-form input,
  .signup-form textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid rgba(1, 3, 38, 0.2);
    background: #fff;
    color: #010326;
  }

  .signup-form button {
    width: fit-content;
    border: 0;
    padding: 0.75rem 1rem;
    background: #D99282;
    color: #fff;
    text-transform: uppercase;
    text-decoration: underline;
    cursor: pointer;
  }
  @media (min-width: 768px){
    .signup-modal__dialog {
    margin: 6rem auto 0;
    padding: 2rem;
  }

    .signup-modal h2 {
    font-size: 2.5rem;
  }

    .signup-form {
    gap: 1rem;
  }

  .signup-form input,
  .signup-form textarea{
    font-size: 1rem;
  }
  .signup-form button{
    font-size: 1.2rem;
  }
  .signup-modal__eyebrow {
    font-size: 1.5rem;
  }
  .signup-modal__event{
    font-size: 1.5rem;
  }
  .signup-form label{
    font-size: 1.5rem;
  }
</style>